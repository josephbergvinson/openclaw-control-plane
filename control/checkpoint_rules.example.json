{
  "rules": [
    {
      "class_id": "bounded_diagnosis",
      "checkpoint_triggers": [
        "blocker",
        "ambiguity",
        "final-synthesis"
      ],
      "batch_window": "short",
      "max_fragmentation": 1,
      "timeliness_target": "coherent-not-streaming"
    },
    {
      "class_id": "multi_pass_research",
      "checkpoint_triggers": [
        "scope-clarified",
        "evidence-collected",
        "blocker",
        "final-synthesis"
      ],
      "batch_window": "short",
      "max_fragmentation": 2,
      "timeliness_target": "batched-phase-change"
    },
    {
      "class_id": "substantial_implementation",
      "checkpoint_triggers": [
        "planning-complete",
        "worker-established",
        "repo-identified",
        "blocker",
        "destructive-boundary",
        "verification-result",
        "fan-in",
        "ready-for-review"
      ],
      "batch_window": "short",
      "max_fragmentation": 3,
      "timeliness_target": "near-phase-change"
    }
  ]
}
